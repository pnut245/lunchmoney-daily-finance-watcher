LUNCHMONEY_ACCESS_TOKEN=replace_with_your_lunch_money_access_token

# Optional: useful for Lunch Money's v2 mock server or future API migration tests.
# LUNCHMONEY_API_BASE_URL=https://api.lunchmoney.dev/v2

# Optional weekly email sending. Leave unset if you only want local email drafts.
# BUDGET_EMAIL_TO=you@example.com
# BUDGET_EMAIL_FROM=you@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=replace_with_smtp_app_password
# SMTP_USE_TLS=true

# Optional Slack incoming webhook for completion notices.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
